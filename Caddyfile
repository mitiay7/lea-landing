:80 {
    root * /srv
    file_server
    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Cache-Control "public, max-age=60"
    }

    handle_errors {
        rewrite * /index.html
        file_server
    }
}
